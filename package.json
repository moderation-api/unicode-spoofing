{
  "name": "@moderation-api/unicode-spoofing",
  "version": "0.1.0",
  "description": "Unicode spoofing detection: mixed-script words, UTS #39 confusables, invisible characters, and combining-mark abuse. Zero runtime dependencies.",
  "author": "Moderation API <support@moderationapi.com>",
  "license": "MIT",
  "repository": "github:moderation-api/unicode-spoofing",
  "homepage": "https://github.com/moderation-api/unicode-spoofing#readme",
  "bugs": "https://github.com/moderation-api/unicode-spoofing/issues",
  "keywords": [
    "unicode",
    "spoofing",
    "homoglyph",
    "confusables",
    "uts39",
    "mixed-script",
    "moderation",
    "security"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:data": "node scripts/generate-confusables.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.2",
    "globals": "^17.7.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
